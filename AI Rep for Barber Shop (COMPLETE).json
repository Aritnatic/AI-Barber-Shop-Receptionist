      "parameters": {
        "jsCode": "// Get data from the Google Sheet node\nconst input = $input.item.json;\nconst slot = input.Slot; // This is \"11:00\"\n\nlet startTime = slot;\nlet endTime;\n\n// Logic to create a 30-minute window\nif (slot.includes(':')) {\n    let [hours, minutes] = slot.split(':');\n    if (minutes === '00') {\n        endTime = `${hours}:30`;\n    } else if (minutes === '30') {\n        endTime = `${parseInt(hours) + 1}:00`;\n    } else {\n        endTime = `${hours}:59`;\n    }\n}\n\nreturn {\n  name: input.Name,\n  date: input.Date,\n  service: input.Service,\n  phone: input.Phone,\n  start_time: startTime,\n  end_time: endTime\n};"
      },
