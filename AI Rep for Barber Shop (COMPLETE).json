    {
      "parameters": {
        "jsCode": "const booked = [];\nfor (const item of items) {\n  const start = item.json?.[\"start_time\"]; \n  const end = item.json?.[\"end_time\"];\n  if (start && end) {\n    booked.push({ start, end });\n  }\n}\nreturn [{ json: { booked } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        0
      ],
      "id": "8f92f2ae-5c5e-4936-b92a-75e6e5bf3001",
      "name": "check booked"
    },
    {
      "parameters": {
        "jsCode": "function toMinutes(t) {\n  const [h, m] = t.split(':').map(Number);\n  return h * 60 + m;\n}\nfunction toTime(m) {\n  const h = String(Math.floor(m / 60)).padStart(2, '0');\n  const min = String(m % 60).padStart(2, '0');\n  return `${h}:${min}`;\n}\nconst OPEN = toMinutes(\"09:00\");\nconst CLOSE = toMinutes(\"18:00\");\nconst SLOT = 30;\nconst bookedData = $input.item.json.booked || [];\nconst booked = bookedData.map(b => ({\n  start: toMinutes(b.start),\n  end: toMinutes(b.end),\n}));\nconst available = [];\nfor (let t = OPEN; t + SLOT <= CLOSE; t += SLOT) {\n  const overlap = booked.some(b => t < b.end && (t + SLOT) > b.start);\n  if (!overlap) {\n    available.push({ start: toTime(t), end: toTime(t + SLOT) });\n  }\n}\nreturn [{ json: { available } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        576,
        0
      ],
